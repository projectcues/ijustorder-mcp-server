# iJustOrder MCP Server Configuration
# Copy this file to .env and fill in your values

# Supabase Edge Function base URL
SUPABASE_URL=https://zztwxyleihgjqisjlalb.supabase.co/functions/v1

# Supabase anon key (public, safe to share)
